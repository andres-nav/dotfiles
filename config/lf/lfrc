cmd open_terminal &{{
	alacritty --hold $F
}}

cmd hide_if_file &{{
    if test -f "$f"; then
	lf -remote "send $id hide"
    fi
}}

cmd hide &{{
    i3-msg [class="scratch"] scratchpad show
}}

cmd open_and_close_scratchpad :hide_if_file; open

cmd open_emacsclient &{{
	pwd | sed -r "s/\s/\\\ /g" | emacsclient .
}}

